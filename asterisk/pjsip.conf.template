; Extension 6003 -- browser softphone (WebRTC over WebSocket)
[6003]
type=endpoint
context=internal
disallow=all
allow=opus
allow=ulaw
auth=auth6003
aors=6003
webrtc=yes
dtls_auto_generate_cert=yes
rewrite_contact=yes

[auth6003]
type=auth
auth_type=userpass
username=6003
password=${SIP_PASS_03}

[6003]
type=aor
max_contacts=2
remove_existing=yes
qualify_frequency=30
